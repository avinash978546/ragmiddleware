# RAG-Guard Local Environment Configurations (No Secrets)

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma3:1b

# Embedding Configuration
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Qdrant Database Configuration
# Set to a local path for embedded/local mode (e.g., data/qdrant_db)
QDRANT_PATH=data/qdrant_db

# Middleware Safety Guards (M3/M4)
# Configurable actions for prompt injection: block (reject query), strip (remove chunk), flag (only log)
INJECTION_POLICY=block
INJECTION_THRESHOLD=0.5
PII_ENABLED=True
